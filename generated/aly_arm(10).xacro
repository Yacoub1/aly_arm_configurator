<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="aly_arm">

  <xacro:property name="j0_x" value="0.0030" />
  <xacro:property name="j1_z" value="0.0804" />
  <xacro:property name="phi_1" value="0.0000" />
  <xacro:property name="phi_2" value="1.5700" />
  <xacro:property name="phi_3" value="0.0000" />

  <link name="world"/>

  <joint name="world_joint" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
