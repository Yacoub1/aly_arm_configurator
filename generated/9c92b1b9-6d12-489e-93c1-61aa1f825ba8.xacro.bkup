<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="aly_arm">

  <!-- Base offset -->
  <xacro:property name="j0_x" value="0.0030" />
  <!-- Configuration offset angles -->
  <xacro:property name="phi_1" value="0.0000" />

  <link name="world"/>

  <joint name="world_joint" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual><geometry>
      <mesh filename="package://aly_arm_0_description/meshes/base_fixture-Body.dae" scale="1 1 1"/>
    </geometry></visual>
    <collision><geometry>
      <mesh filename="package://aly_arm_0_description/meshes/base_fixture-Body.dae" scale="1 1 1"/>
    </geometry></collision>
  </link>

  <joint name="base_holder_joint" type="fixed">
    <parent link="base_link"/>
    <child link="motor_holder_link"/>
    <origin xyz="${j0_x} 0 0" rpy="0 0 0"/>
  </joint>

  <link name="motor_holder_link">
    <visual><geometry>
      <mesh filename="package://aly_arm_0_description/meshes/base_motorholder_90deg_V4-Body.dae" scale="1 1 1"/>
    </geometry></visual>
    <collision><geometry>
      <mesh filename="package://aly_arm_0_description/meshes/base_motorholder_90deg_V4-Body.dae" scale="1 1 1"/>
    </geometry></collision>
  </link>

  <joint name="config_joint_0" type="fixed">
    <parent link="motor_holder_link"/>
    <child link="link_motor_0_0"/>
    <origin xyz="0 0 0" rpy="0 ${phi_1} 0"/>
  </joint>

  <link name="link_motor_0_0">
    <visual>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
      <geometry><mesh filename="package://aly_arm_0_description/meshes/motor_assembly.dae" scale="1 1 1"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
      <geometry><mesh filename="package://aly_arm_0_description/meshes/motor_assembly.dae" scale="1 1 1"/></geometry>
    </collision>
  </link>

  <joint name="joint_0" type="revolute">
    <parent link="link_motor_0_0"/>
    <child link="link_active_0_1"/>
    <origin xyz="0.036 0 0" rpy="0 ${phi_1} 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="10.0000" lower="-1.2500" upper="1.2000" velocity="1.0000"/>
  </joint>

  <link name="link_active_0_1">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://aly_arm_0_description/meshes/lnk_active_0deg_hirth_18d0_V2_a2plus-Part.dae" scale="1 1 1"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://aly_arm_0_description/meshes/lnk_active_0deg_hirth_18d0_V2_a2plus-Part.dae" scale="1 1 1"/></geometry>
    </collision>
  </link>

</robot>